{
  "name": "apply-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node -e \"const fs=require('fs'),path=require('path');if(fs.existsSync('dist'))fs.rmSync('dist',{recursive:true});fs.mkdirSync('dist');['popup','lib','data','manifest.json','background','content'].forEach(f=>fs.cpSync(f,path.join('dist',f),{recursive:true}))\"",
    "test": "node --test tests/*.test.mjs",
    "test:coverage": "node --experimental-test-coverage --test tests/*.test.mjs",
    "test:e2e": "playwright test --config config/playwright.config.mjs",
    "test:e2e-headed": "playwright test --headed",
    "lint": "eslint popup/popup.js lib/*.js --max-warnings=0 --config config/eslint.config.mjs"
  },
  "dependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^10.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@playwright/test": "1.61.1",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1"
  }
}
